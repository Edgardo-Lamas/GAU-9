# ============================================================
# GAU-9 — Variables de Entorno
# Copiar a .env y completar con los valores reales
# NUNCA commitear el archivo .env
# ============================================================

# Base de datos (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/gau9

# Google Drive (Service Account)
# Ruta al archivo JSON de credenciales de la service account
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/service_account.json
GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.readonly

# API
PORT=3000
NODE_ENV=development

# Sincronización
SYNC_INTERVALO_MINUTOS=30

# JWT
JWT_SECRET=reemplazar_con_secreto_largo_aleatorio_de_al_menos_32_caracteres
JWT_EXPIRES_IN=8h
