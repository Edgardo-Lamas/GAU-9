{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/health",
      "dest": "api/index.js"
    },
    {
      "src": "/verificar/(.*)",
      "dest": "dashboard/verificar.html"
    },
    {
      "src": "/(.*)",
      "dest": "dashboard/$1"
    }
  ]
}
